digraph depdog {
  rankdir=LR;
  node [shape=box];
  "service-a" [label="service-a «cmd-services»"];
  "service-b" [label="service-b «cmd-services»"];
  "shared";
  "service-a" -> "shared";
  "service-b" -> "service-a" [color="red", penwidth=2];
  "shared" -> "service-a" [color="red", penwidth=2];
}
