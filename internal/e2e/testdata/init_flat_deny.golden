# depdog.yaml — generated by `depdog init` (preset: flat, policy: deny).
# Components map package directories to layers; rules declare who may import whom.
# policy: deny is the whitelist stance — only imports a rule allows are permitted.
# Review this file, then run `depdog check`.
version: 1

components:
  cmd:        ["cmd/**"]                  # proposed from directory scan — review this rule
  domain:     ["internal/domain/**"]      # proposed from directory scan — review this rule
  handler:    ["internal/handler/**"]     # proposed from directory scan — review this rule
  repository: ["internal/repository/**"]  # proposed from directory scan — review this rule
  service:    ["internal/service/**"]     # proposed from directory scan — review this rule
  telemetry:  ["internal/telemetry/**"]   # proposed from directory scan — review this rule
  util:       ["pkg/util/**"]             # proposed from directory scan — review this rule

policy: deny

rules:
  cmd:        { allow: ["*"] }
  domain:     { allow: [std, external] }
  handler:    { allow: [std, external] }
  repository: { allow: [std, external] }
  service:    { allow: [std, external] }
  telemetry:  { allow: [std, external] }
  util:       { allow: [std, external] }
