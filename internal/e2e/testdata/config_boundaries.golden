default:    allow
test_files: hybrid

components:
  service-a  cmd/service-a/**
             stance: whitelist (only allowed pass)
             allow:  [*]
  service-b  cmd/service-b/**
             stance: whitelist (only allowed pass)
             allow:  [*]
  shared     internal/**
             stance: whitelist (only allowed pass)
             allow:  [*]

boundaries:
  cmd-services (sealed)  service-a, service-b
