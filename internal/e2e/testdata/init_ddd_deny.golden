# depdog.yaml — generated by `depdog init` (preset: ddd, default: deny).
# Each component lists its path glob(s) and, inline, who it may import.
# default: deny is the whitelist stance — a rule-less component may import nothing.
# Review this file, then run `depdog check`.
version: 2

components:
  main:       { path: "cmd/**",                 allow: ["*"] }            # wires everything together
  domain:     { path: "internal/domain/**",     allow: [std] }            # the pure core: standard library only
  handler:    { path: "internal/handler/**",    allow: [domain, std, external] }
  service:    { path: "internal/service/**",    allow: [domain, std, external] }
  repository: { path: "internal/repository/**", allow: [domain, std, external] }
  telemetry:  { path: "internal/telemetry/**",  allow: [std, external] }  # proposed from directory scan — review this rule
  util:       { path: "pkg/util/**",            allow: [std, external] }  # proposed from directory scan — review this rule

default: deny
