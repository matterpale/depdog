# depdog.yaml — generated by `depdog init` (preset: ddd, policy: deny).
# Components map package directories to layers; rules declare who may import whom.
# policy: deny is the whitelist stance — only imports a rule allows are permitted.
# Review this file, then run `depdog check`.
version: 1

components:
  main:       ["cmd/**"]                 # wires everything together
  domain:     ["internal/domain/**"]     # the pure core: standard library only
  handler:    ["internal/handler/**"]
  service:    ["internal/service/**"]
  repository: ["internal/repository/**"]
  telemetry:  ["internal/telemetry/**"]  # proposed from directory scan — review this rule
  util:       ["pkg/util/**"]            # proposed from directory scan — review this rule

policy: deny

rules:
  main:       { allow: ["*"] }
  domain:     { allow: [std] }
  handler:    { allow: [domain, std, external] }
  service:    { allow: [domain, std, external] }
  repository: { allow: [domain, std, external] }
  telemetry:  { allow: [std, external] }
  util:       { allow: [std, external] }
