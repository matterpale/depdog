# depdog.yaml — generated by `depdog init` (preset: ddd, default: allow).
# Each component lists its path glob(s) and, inline, who it may import.
# default: allow is the blacklist stance — a rule-less component may import anything.
# Review this file, then run `depdog check`.
version: 2

components:
  main:       { path: "cmd/**" }                                                                              # wires everything together
  domain:     { path: "internal/domain/**",     deny: [handler, service, repository, external, unassigned] }  # the pure core: standard library only
  handler:    { path: "internal/handler/**",    deny: [service, repository] }
  service:    { path: "internal/service/**",    deny: [handler, repository] }
  repository: { path: "internal/repository/**", deny: [handler, service] }
  telemetry:  { path: "internal/telemetry/**" }                                                               # proposed from directory scan — review this rule
  util:       { path: "pkg/util/**" }                                                                         # proposed from directory scan — review this rule

default: allow
