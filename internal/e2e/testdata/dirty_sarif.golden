{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "depdog",
          "informationUri": "https://github.com/matterpale/depdog",
          "version": "0.0.0-dev",
          "rules": [
            {
              "id": "domain",
              "shortDescription": {
                "text": "Import rules for component domain"
              }
            },
            {
              "id": "handler",
              "shortDescription": {
                "text": "Import rules for component handler"
              }
            },
            {
              "id": "unassigned-package",
              "shortDescription": {
                "text": "Package not covered by any component"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "domain",
          "level": "error",
          "message": {
            "text": "domain imports example.test/dirty/internal/repository (domain: allow [std]) — `example.test/dirty/internal/domain/pricing` (component `domain`) may import only `std`; `example.test/dirty/internal/repository` (component `repository`) is not among them. Fix: add `repository` to `domain`'s allow list, or depend only on what `domain` already allows."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "internal/domain/pricing/discount.go"
                },
                "region": {
                  "startLine": 3
                }
              }
            },
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "internal/domain/pricing/pricing.go"
                },
                "region": {
                  "startLine": 5
                }
              }
            }
          ]
        },
        {
          "ruleId": "domain",
          "level": "error",
          "message": {
            "text": "domain imports example.test/extlib (domain: allow [std]) — `example.test/dirty/internal/domain/pricing` (component `domain`) may import only `std`; `example.test/extlib` (an external dependency) is not among them. Fix: add `example.test/extlib` to `domain`'s allow list, or depend only on what `domain` already allows."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "internal/domain/pricing/pricing.go"
                },
                "region": {
                  "startLine": 6
                }
              }
            }
          ]
        },
        {
          "ruleId": "handler",
          "level": "error",
          "message": {
            "text": "handler imports example.test/dirty/internal/repository (handler: allow [domain, std]) — `example.test/dirty/internal/handler/checkout` (component `handler`) may import only `domain`, `std`; `example.test/dirty/internal/repository` (component `repository`) is not among them. Fix: add `repository` to `handler`'s allow list, or depend only on what `handler` already allows."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "internal/handler/checkout/checkout_test.go"
                },
                "region": {
                  "startLine": 6
                }
              }
            }
          ]
        },
        {
          "ruleId": "handler",
          "level": "error",
          "message": {
            "text": "handler imports example.test/dirty/internal/service (handler: allow [domain, std]) — `example.test/dirty/internal/handler/checkout` (component `handler`) may import only `domain`, `std`; `example.test/dirty/internal/service` (component `service`) is not among them. Fix: add `service` to `handler`'s allow list, or depend only on what `handler` already allows."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "internal/handler/checkout/checkout.go"
                },
                "region": {
                  "startLine": 5
                }
              }
            }
          ]
        },
        {
          "ruleId": "unassigned-package",
          "level": "note",
          "message": {
            "text": "example.test/dirty/internal/util is not covered by any component"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "internal/util"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
